    return HttpResponse(page)


@staff_member_required
def admin_export_user_posts(request, username):
    target_user = get_object_or_404(User, username=username)
    if log_security_event:
        log_security_event(
            request=request,
            event_type="post_export_admin",
            severity="info",
            message=f"Admin je izvezao postove korisnika {target_user.username}.",
            user=request.user,
            username=request.user.username,
            metadata={"target_username": target_user.username, "target_user_id": target_user.id},
        )
    return _export_response(target_user, exported_by=request.user)
