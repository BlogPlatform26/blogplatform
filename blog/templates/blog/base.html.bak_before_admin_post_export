            const current = tailPoints[i];
            const previous = i === 0 ? { x: lastX, y: lastY } : tailPoints[i - 1];
            const dx = previous.x - current.x;
            const dy = previous.y - current.y;
            const angle = Math.atan2(dy, dx) * 180 / Math.PI;
            const length = Math.hypot(dx, dy) || 1;
            const normalX = length ? -dy / length : 0;
            const normalY = length ? dx / length : 0;
            const progress = i / Math.max(1, tailSegments.length - 1);

            const swayStrength = isIdle
                ? ((tailConfig.idleCurlAmplitude || 3) * 0.6 + (tailConfig.idleExtraAmplitude || 2.2) * 0.45)
