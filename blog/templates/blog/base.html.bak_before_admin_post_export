        const pointerSpeed = Math.min(46, Math.hypot(lastPointerVX, lastPointerVY));
        const targetMotionEnergy = isIdle ? 0 : Math.min(1, pointerSpeed / 18);
        tailMotionEnergy += (targetMotionEnergy - tailMotionEnergy) * (isIdle ? 0.06 : 0.22);
        tailStretchEnergy += (tailMotionEnergy - tailStretchEnergy) * (isIdle ? 0.05 : 0.16);

        const pointerHeading = normalizeVector(lastPointerVX, lastPointerVY);
        const headingEase = isIdle ? 0.035 : Math.min(0.22, 0.09 + dt * 2.8 + tailMotionEnergy * 0.07);
        tailHeadingX += (pointerHeading.x - tailHeadingX) * headingEase;
        tailHeadingY += (pointerHeading.y - tailHeadingY) * headingEase;
        const stableHeading = normalizeVector(tailHeadingX, tailHeadingY);
        tailHeadingX = stableHeading.x;
        tailHeadingY = stableHeading.y;

        if (!tailInitialized) {
            let offset = 0;
            for (let i = 0; i < tailPoints.length; i += 1) {
                offset += tailPoints[i].stepDistance;
                tailPoints[i].x = lastX - tailHeadingX * offset;
                tailPoints[i].y = lastY - tailHeadingY * offset;
                tailPoints[i].vx = 0;
                tailPoints[i].vy = 0;
            }
            tailInitialized = true;
        }

        if (isIdle) {
            const normalX = -tailHeadingY;
            const normalY = tailHeadingX;
            let offset = 0;

            for (let i = 0; i < tailPoints.length; i += 1) {
                const point = tailPoints[i];
                const progress = i / Math.max(1, tailPoints.length - 1);
                offset += point.stepDistance * Math.max(1.04, (tailConfig.idleHoldDistance || 1.03) + 0.02);

                const swayPhase = (ts / Math.max(220, tailConfig.idleWaveSpeed || 320)) + i * ((tailConfig.phaseStep || 0.6) * 0.94);
                const bobPhase = (ts / Math.max(180, (tailConfig.bobSpeed || 260) * 1.08)) + i * 0.48;
                const swirlPhase = (ts / 520) + i * 0.31;

                const lateralSway = Math.sin(swayPhase)
                    * ((tailConfig.idleCurlAmplitude || 3) + (tailConfig.idleExtraAmplitude || 2.2) * 0.65)
                    * Math.max(0.32, 1 - progress * 0.1);
                const bobSway = Math.cos(bobPhase)
                    * ((tailConfig.bobAmplitude || 1.1) * 1.15)
                    * Math.max(0.25, 1 - progress * 0.08);
