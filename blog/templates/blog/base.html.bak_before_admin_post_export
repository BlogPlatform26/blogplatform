<script>
(function () {
    const widget = document.getElementById('ambientMusicWidget');
    const player = document.getElementById('ambientMusicPlayer');
    const toggle = document.getElementById('ambientMusicToggle');
    const panel = widget ? widget.querySelector('.ambient-music-panel') : null;
    const toggleIcon = document.getElementById('ambientMusicToggleIcon');
    const status = document.getElementById('ambientMusicStatus');

    if (!widget || !player || !toggle || !panel || !toggleIcon || !status) {
        return;
    }

    const prefix = widget.dataset.storagePrefix || 'blogAmbientMusic';
    const volumeKey = prefix + ':volume';
    const playKey = prefix + ':playing';
    const timeKey = prefix + ':time';
    const sourceKey = prefix + ':source';
    const trackKey = prefix + ':track';
    const currentTrackId = widget.dataset.trackId || '';
    const defaultVolume = Math.max(0, Math.min(1, (parseInt(widget.dataset.volume || '18', 10) || 18) / 100));
    let closeTimer = null;

    function setStatus(text) {
        status.textContent = text;
    }

    function openWidget() {
        widget.classList.add('is-open');
    }

    function closeWidget() {
        widget.classList.remove('is-open');
    }

    function clearCloseTimer() {
        if (closeTimer) {
            window.clearTimeout(closeTimer);
            closeTimer = null;
        }
    }

    function scheduleClose(delay) {
        clearCloseTimer();
        closeTimer = window.setTimeout(function () {
            closeWidget();
        }, delay || 2200);
    }

    function updateButton(isPlaying) {
        toggle.setAttribute('aria-pressed', isPlaying ? 'true' : 'false');
        toggleIcon.className = isPlaying ? 'bi bi-pause-fill' : 'bi bi-play-fill';
        setStatus(isPlaying ? 'Svira u pozadini' : 'Klikni za reprodukciju');
    }

    function savePlaybackState() {
        try {
            sessionStorage.setItem(playKey, player.paused ? '0' : '1');
            sessionStorage.setItem(timeKey, String(player.currentTime || 0));
            localStorage.setItem(volumeKey, String(player.volume));
            localStorage.setItem(sourceKey, window.location.pathname);
            sessionStorage.setItem(trackKey, currentTrackId);
        } catch (error) {
        }
    }

    function applySavedTime() {
        try {
            const savedTrackId = sessionStorage.getItem(trackKey) || '';
            if (savedTrackId && currentTrackId && savedTrackId !== currentTrackId) {
                return;
            }

            const savedTime = parseFloat(sessionStorage.getItem(timeKey) || '0');
            if (Number.isFinite(savedTime) && savedTime > 0) {
                const applyTime = function () {
                    try {
                        if (savedTime < player.duration - 0.35 || !Number.isFinite(player.duration)) {
                            player.currentTime = savedTime;
                        }
                    } catch (error) {
                    }
                };

                if (player.readyState >= 1) {
                    applyTime();
                } else {
                    player.addEventListener('loadedmetadata', applyTime, { once: true });
                }
            }
        } catch (error) {
        }
    }

    function playAudio(fromRestore) {
        openWidget();
        const playAttempt = player.play();
        if (playAttempt && typeof playAttempt.then === 'function') {
            playAttempt.then(function () {
                updateButton(true);
                if (fromRestore) {
                    setStatus('Glazba je ponovno uključena');
                    window.setTimeout(function () {
                        if (!player.paused) {
                            setStatus('Svira u pozadini');
                        }
                    }, 1400);
                }
                scheduleClose(2600);
            }).catch(function () {
                updateButton(false);
                setStatus('Klikni za reprodukciju');
                scheduleClose(2200);
            });
        } else {
            updateButton(!player.paused);
            scheduleClose(2600);
        }
    }

    try {
        const savedVolume = parseFloat(localStorage.getItem(volumeKey) || '');
        player.volume = Number.isFinite(savedVolume) ? Math.max(0, Math.min(1, savedVolume)) : defaultVolume;
    } catch (error) {
        player.volume = defaultVolume;
    }

    applySavedTime();
    updateButton(false);
    scheduleClose(1800);

    toggle.addEventListener('click', function () {
        openWidget();
        if (player.paused) {
            playAudio(false);
        } else {
            player.pause();
            updateButton(false);
            scheduleClose(2200);
        }
        savePlaybackState();
    });

    toggle.addEventListener('mouseenter', function () {
        clearCloseTimer();
        openWidget();
    });

    toggle.addEventListener('mouseleave', function () {
        scheduleClose(player.paused ? 1400 : 2400);
    });

    panel.addEventListener('mouseenter', function () {
        clearCloseTimer();
        openWidget();
    });

    panel.addEventListener('mouseleave', function () {
        scheduleClose(player.paused ? 1400 : 2400);
    });

    widget.addEventListener('focusin', function () {
        clearCloseTimer();
        openWidget();
    });

    widget.addEventListener('focusout', function () {
        scheduleClose(player.paused ? 1400 : 2400);
    });

    player.addEventListener('play', function () {
        updateButton(true);
        openWidget();
        savePlaybackState();
        scheduleClose(2600);
    });

    player.addEventListener('pause', function () {
        updateButton(false);
        savePlaybackState();
        scheduleClose(2200);
    });

    player.addEventListener('volumechange', savePlaybackState);
    window.addEventListener('pagehide', savePlaybackState);
    window.setInterval(function () {
        if (!player.paused) {
            savePlaybackState();
        }
    }, 1500);

    let shouldRestore = false;
    try {
        shouldRestore = sessionStorage.getItem(playKey) === '1'
            && (sessionStorage.getItem(trackKey) || '') === currentTrackId;
    } catch (error) {
        shouldRestore = false;
    }

    if (shouldRestore) {
        const resumePlayback = function () {
            playAudio(true);
        };

        if (player.readyState >= 2) {
            resumePlayback();
        } else {
            player.addEventListener('canplay', resumePlayback, { once: true });
        }
    }
})();
</script>

