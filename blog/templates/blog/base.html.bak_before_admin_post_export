<!DOCTYPE html>
<html>
<head>
    {% load static %}
    {% load custom_tags %}
    <link rel="icon" type="image/png" href="{% static 'images/favicon.png' %}?v=2">
    <link rel="shortcut icon" href="{% static 'images/favicon.png' %}?v=2">
    <link rel="apple-touch-icon" href="{% static 'images/favicon.png' %}?v=2">
    <link rel="stylesheet" href="{% static 'css/style.css' %}">
    <title>{% block title %}Blog{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    {% if request.resolver_match.url_name != 'login' and request.resolver_match.url_name != 'register' and request.resolver_match.url_name != 'activation_sent' and request.resolver_match.url_name != 'author_onboarding' and request.resolver_match.url_name != 'password_reset' and request.resolver_match.url_name != 'password_reset_done' and request.resolver_match.url_name != 'password_reset_confirm' and request.resolver_match.url_name != 'password_reset_complete' and blog_preferences.cursor_stylesheet_url %}<link rel="stylesheet" href="{{ blog_preferences.cursor_stylesheet_url }}">{% endif %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
    <meta name="csrf-token" content="{{ csrf_token }}">

    <style>
    .unread-notification {
        background-color: rgba(61, 61, 61, 0.274);
    }

    /* ako ti nema u style.css */
    .nav-right{
        gap: 14px;
        align-items: center;
    }
    .nav-icon{
        color: rgba(255,255,255,0.92);
        text-decoration: none;
        padding: 6px 10px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .nav-icon:hover{
        background: rgba(255,255,255,0.08);
        color: #fff;
    }
    .nav-user{
        color: rgba(255,255,255,0.92);
        text-decoration: none;
        padding: 6px 10px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    .nav-user:hover{
        background: rgba(255,255,255,0.08);
        color: #fff;
    }
    .nav-avatar{
        width: 28px;
        height: 28px;
        border-radius: 50%;
        object-fit: cover;
    }
    .nav-user-text{ line-height: 1; }
    .notif-badge{ font-size: 11px; padding: 3px 6px; }
    .notif-menu{ width: 360px; max-height: 420px; overflow-y: auto; }
    .notif-actions-bar{
        position: sticky;
        top: 0;
        z-index: 5;
        background: #fff;
    }
    .notif-actions-bar .btn-link:disabled{
        color: rgba(0,0,0,0.35) !important;
        pointer-events: none;
    }


    .live-analytics-widget{
        margin-top: 16px;
    }
    .live-analytics-widget--full{
        width: 100% !important;
        max-width: none !important;
        margin: 0 !important;
        margin-bottom: 24px !important;
    }
    .live-analytics-widget--full .sidebar-box-content{
        padding-bottom: 18px;
    }
    .live-analytics-layout-grid{
        display:flex;
        flex-direction:column;
        gap:16px;
    }
    .live-analytics-section{
        min-width:0;
    }
    .live-analytics-widget--full .live-analytics-layout-grid{
        display:grid;
        grid-template-columns: minmax(220px, 0.95fr) minmax(260px, 1.05fr) minmax(340px, 1.5fr);
        align-items:start;
        gap:18px;
    }
    .live-analytics-widget--full .live-analytics-section{
        height:100%;
    }
    .live-analytics-widget--full .live-analytics-section--map .analytics-map-canvas--map{
        height: 330px;
    }
    .live-analytics-widget--full .live-analytics-section--map .analytics-map-canvas--globe{
        height: 360px;
    }
    .live-analytics-widget--full .live-analytics-section--map .analytics-map-wrapper{
        height:100%;
    }
    .live-analytics-widget--full .live-analytics-widget-note{
        margin-top: 14px !important;
    }
    .analytics-footer-slot{
        margin-top: 28px;
        margin-bottom: 10px;
    }
    @media (max-width: 991.98px){
        .live-analytics-widget--full .live-analytics-layout-grid{
            grid-template-columns: 1fr;
        }
    }
    .live-analytics-stats{
        --analytics-stat-gap: 6px;
        --analytics-stat-card-padding-y: 5px;
        --analytics-stat-card-padding-x: 4px;
        --analytics-stat-value-size: 0.88rem;
        --analytics-stat-label-size: 9px;
        --analytics-stat-radius: 11px;
        display:grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap:var(--analytics-stat-gap);
    }
    .live-analytics-stats--medium{
        --analytics-stat-gap: 8px;
        --analytics-stat-card-padding-y: 8px;
        --analytics-stat-card-padding-x: 6px;
        --analytics-stat-value-size: 1.04rem;
        --analytics-stat-label-size: 10px;
        --analytics-stat-radius: 13px;
    }
    .live-analytics-stats--large{
        --analytics-stat-gap: 10px;
        --analytics-stat-card-padding-y: 10px;
        --analytics-stat-card-padding-x: 8px;
        --analytics-stat-value-size: 1.18rem;
        --analytics-stat-label-size: 11px;
        --analytics-stat-radius: 14px;
    }
    .live-analytics-stat-card{
        border:1px solid var(--analytics-stat-card-border, rgba(0,0,0,0.08));
        border-radius:var(--analytics-stat-radius);
        padding:var(--analytics-stat-card-padding-y) var(--analytics-stat-card-padding-x);
        text-align:center;
        background:var(--analytics-stat-card-bg, #fafafa);
        box-shadow:var(--analytics-stat-card-shadow, none);
        color:var(--analytics-stat-card-color, inherit);
    }
    .live-analytics-stat-value{
        font-size:var(--analytics-stat-value-size);
        font-weight:700;
        line-height:1.02;
        color:var(--analytics-stat-value-color, inherit);
    }
    .live-analytics-stat-label{
        font-size:var(--analytics-stat-label-size);
        color:var(--analytics-stat-label-color, #6c757d);
        margin-top:2px;
        line-height:1.1;
    }
    .live-analytics-pages{
        display:flex;
        flex-direction:column;
        gap:6px;
    }
    .live-analytics-page-row{
        display:flex;
        justify-content:space-between;
        align-items:center;
        gap:10px;
        padding:6px 8px;
        border-radius:10px;
        background:var(--analytics-page-row-bg, #fafafa);
        border:1px solid var(--analytics-page-row-border, rgba(0,0,0,0.06));
        color:var(--analytics-page-row-color, inherit);
        font-size:12px;
    }
    .analytics-map-wrapper{

        width:100%;
    }
    .analytics-map-card{
        position:relative;
        background:var(--analytics-map-card-bg, linear-gradient(180deg, rgba(255,255,255,0.995) 0%, rgba(246,248,252,0.995) 100%));
        border:1px solid var(--analytics-map-card-border, rgba(15, 23, 42, 0.08));
        border-radius:18px;
        padding:8px;
        box-shadow:var(--analytics-map-card-shadow, 0 10px 22px rgba(15, 23, 42, 0.05));
    }
    .analytics-map-card--globe{
        background:transparent;
        border:none;
        box-shadow:none;
        padding:0;
    }
    .analytics-map-canvas{
        width:100%;
        height:240px;
        border-radius:20px;
        overflow:hidden;
    }
    .analytics-map-canvas--map{
        background:
            radial-gradient(circle at 50% 15%, rgba(125, 211, 252, 0.18), transparent 34%),
            linear-gradient(180deg, #08172f 0%, #0b1f3f 100%);
        border:1px solid rgba(96, 165, 250, 0.18);
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.06);
    }
    .analytics-map-canvas--globe{
        height:340px;
        background:transparent;
        border-radius:0;
        overflow:visible;
        cursor:grab;
        touch-action:none;
        user-select:none;
    }
    .analytics-map-canvas--globe.is-dragging{
        cursor:grabbing;
    }
    .analytics-map-canvas--globe canvas{
        display:block;
        background:transparent !important;
    }
    nav.navbar{
        position:relative;
        z-index:5000 !important;
    }
    nav.navbar .dropdown-menu{
        z-index:5100 !important;
    }

    .analytics-map-canvas .leaflet-control-attribution{
        font-size:10px;
        background:rgba(255,255,255,0.88);
        border-radius:10px;
        padding:2px 6px;
        backdrop-filter:blur(6px);
    }
    .analytics-map-canvas .leaflet-container{
        background:#08172f;
        font-family:inherit;
    }
    .analytics-map-canvas .leaflet-tile{
        filter:saturate(1.08) contrast(1.04) brightness(1.02);
    }
    .analytics-map-canvas .leaflet-pane.analytics-map-labels-pane{
        z-index: 480;
        pointer-events:none;
    }
    .analytics-map-canvas .leaflet-pane.analytics-map-labels-pane .leaflet-tile{
        filter: contrast(1.02) brightness(1.03);
    }
    .analytics-map-canvas .leaflet-control-zoom{
        box-shadow:none;
        border:1px solid rgba(15, 23, 42, 0.08);
        border-radius:12px;
        overflow:hidden;
    }
    .analytics-map-canvas .leaflet-control-zoom a{
        color:#1f2937;
        background:rgba(255,255,255,0.96);
    }
    .analytics-map-canvas .leaflet-popup-content-wrapper,
    .analytics-map-canvas .leaflet-popup-tip{
        box-shadow:0 12px 30px rgba(15, 23, 42, 0.12);
    }
    .analytics-map-empty{
        background:#fafbfd;
    }
    .analytics-globe-dot{
        display:block;
        width:9px;
        height:9px;
        aspect-ratio:1/1;
        border-radius:999px;
        background:#ef4444;
        box-shadow:0 0 0 2px rgba(255,255,255,0.97), 0 0 14px rgba(239, 68, 68, 0.26);
        pointer-events:auto;
        cursor:pointer;
        transform:translate(-50%, -50%);
        will-change:transform;
    }
    .blog-cursor-theme:not(.blog-cursor-external-style) input[type="text"],
    .blog-cursor-theme:not(.blog-cursor-external-style) input[type="email"],
    .blog-cursor-theme:not(.blog-cursor-external-style) input[type="password"],
    .blog-cursor-theme:not(.blog-cursor-external-style) input[type="search"],
    .blog-cursor-theme:not(.blog-cursor-external-style) input[type="number"],
    .blog-cursor-theme:not(.blog-cursor-external-style) textarea,
    .blog-cursor-theme:not(.blog-cursor-external-style) [contenteditable="true"]{
        cursor:text !important;
    }

