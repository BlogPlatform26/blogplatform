<script>
(function () {
    function readMapPoints(container) {
        return Array.from(container.querySelectorAll('[data-map-point]')).map(function (item) {
            return {
                latitude: Number(item.dataset.lat),
                longitude: Number(item.dataset.lng),
                count: Number(item.dataset.count || 1),
                label: item.dataset.label || 'Približna lokacija posjeta',
            };
        }).filter(function (point) {
            return Number.isFinite(point.latitude) && Number.isFinite(point.longitude);
        });
    }

    function normalizePoints(points) {
        return Array.isArray(points) ? points.filter(function (point) {
            return Number.isFinite(Number(point.latitude)) && Number.isFinite(Number(point.longitude));
        }).map(function (point) {
            return {
                latitude: Number(point.latitude),
                longitude: Number(point.longitude),
                count: Number(point.count || 1),
                label: point.label || 'Približna lokacija posjeta',
            };
        }) : [];
    }

    function markerPopupText(point) {
        const base = point.label || 'Približna lokacija posjeta';
        const visits = point.count === 1 ? '1 posjet' : point.count + ' posjeta';
        return '<strong>' + base + '</strong><br>' + visits;
    }

    function markerTitleText(point) {
        const base = point.label || 'Približna lokacija posjeta';
        const visits = point.count === 1 ? '1 posjet' : point.count + ' posjeta';
        return base + ' · ' + visits;
    }

    function pointRadius(point) {
        return Math.min(11, 4.5 + ((point.count || 1) * 0.85));
    }

    function initLeafletMap(container) {
        if (!window.L || container._analyticsLeafletMap) {
            return;
        }

        const worldBounds = [[-85, -180], [85, 180]];
        const map = L.map(container, {
            center: [20, 10],
            zoom: 1.5,
            minZoom: 1,
            maxZoom: 7,
            zoomSnap: 0.25,
            zoomDelta: 0.25,
            worldCopyJump: false,
            scrollWheelZoom: true,
            attributionControl: true,
            zoomControl: true,
            preferCanvas: true,
            maxBounds: worldBounds,
            maxBoundsViscosity: 1,
        });

        map.createPane('analytics-map-labels-pane');
        const labelsPane = map.getPane('analytics-map-labels-pane');
        if (labelsPane) {
            labelsPane.classList.add('analytics-map-labels-pane');
        }

        L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
            noWrap: true,
            bounds: worldBounds,
            minZoom: 1,
            maxZoom: 7,
            updateWhenIdle: true,
            keepBuffer: 2,
        }).addTo(map);

        L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}', {
            noWrap: true,
            bounds: worldBounds,
            minZoom: 1,
            maxZoom: 7,
            opacity: 0.96,
            pane: 'analytics-map-labels-pane',
            updateWhenIdle: true,
            keepBuffer: 2,
        }).addTo(map);

        map.attributionControl.setPrefix('');
        map.attributionControl.addAttribution('Karta: Esri World Imagery · Nazivi: World Boundaries and Places');

        container._analyticsLeafletMap = map;
        container._analyticsMarkerLayer = L.layerGroup().addTo(map);
    }

    function renderLeafletMap(container, points) {
        if (!window.L) {
            return;
        }
        initLeafletMap(container);

        const map = container._analyticsLeafletMap;
        const layer = container._analyticsMarkerLayer;
        layer.clearLayers();

        if (!points.length) {
            map.setView([18, 10], 1.35);
            return;
        }

        const bounds = [];
        points.forEach(function (point) {
            const marker = L.circleMarker([point.latitude, point.longitude], {
                radius: pointRadius(point),
                color: '#ffffff',
                weight: 2,
                fillColor: '#ef4444',
                fillOpacity: 0.88,
            });
            marker.bindPopup(markerPopupText(point));
            marker.bindTooltip(point.label, { sticky: true, direction: 'top' });
            marker.addTo(layer);
            bounds.push([point.latitude, point.longitude]);
        });

        if (bounds.length === 1) {
            map.setView(bounds[0], 3.75);
        } else {
            map.fitBounds(bounds, {
                padding: [28, 28],
                maxZoom: 4,
            });
        }

        window.setTimeout(function () {
            map.invalidateSize();
        }, 120);
    }

    function attachGlobeInteraction(container, globe) {
        if (container._analyticsGlobeState) {
            return container._analyticsGlobeState;
        }

        const controls = globe.controls();
        const state = {
            defaultSpeed: 0.32,
            currentSpeed: 0.32,
            dragging: false,
            pointerMoved: false,
            dragVelocity: 0,
            lastX: 0,
            lastTime: 0,
            inertiaActive: false,
            returnToDefault: false,
            resumeAt: 0,
            rafId: null,
        };

        controls.autoRotate = true;
        controls.autoRotateSpeed = state.defaultSpeed;
        controls.enablePan = false;
        controls.enableZoom = true;
        controls.zoomSpeed = 0.9;
        controls.enableDamping = true;
        controls.dampingFactor = 0.08;
        controls.rotateSpeed = 0.85;

        function animate() {
            if (!container._analyticsGlobe) {
                return;
            }

            const now = window.performance.now();

            if (!state.dragging) {
                if (state.inertiaActive) {
                    state.currentSpeed *= 0.972;
                    if (Math.abs(state.currentSpeed) <= 0.012) {
                        state.currentSpeed = 0;
                        state.inertiaActive = false;
                        state.returnToDefault = true;
                        state.resumeAt = now + 220;
                        controls.autoRotate = false;
                        controls.autoRotateSpeed = 0;
                    } else {
                        controls.autoRotate = true;
                        controls.autoRotateSpeed = state.currentSpeed;
                    }
                } else if (state.returnToDefault) {
                    if (now < state.resumeAt) {
                        controls.autoRotate = false;
                        controls.autoRotateSpeed = 0;
                    } else {
                        const diff = state.defaultSpeed - state.currentSpeed;
                        state.currentSpeed += diff * 0.035;
                        controls.autoRotate = true;
                        controls.autoRotateSpeed = state.currentSpeed;
                        if (Math.abs(diff) < 0.005) {
                            state.currentSpeed = state.defaultSpeed;
                            state.returnToDefault = false;
                            controls.autoRotateSpeed = state.defaultSpeed;
                        }
                    }
                } else {
                    controls.autoRotate = true;
                    controls.autoRotateSpeed = state.defaultSpeed;
                    state.currentSpeed = state.defaultSpeed;
                }
            }

            state.rafId = window.requestAnimationFrame(animate);
        }

        function finishDrag() {
            if (!state.dragging) {
                return;
            }

            state.dragging = false;
            container.classList.remove('is-dragging');

            if (state.pointerMoved && Math.abs(state.dragVelocity) >= 0.008) {
                state.currentSpeed = Math.max(-6.5, Math.min(6.5, state.dragVelocity * -18));
                state.inertiaActive = true;
                state.returnToDefault = false;
                state.resumeAt = 0;
                controls.autoRotate = true;
                controls.autoRotateSpeed = state.currentSpeed;
                return;
            }

            state.currentSpeed = 0;
            state.inertiaActive = false;
            state.returnToDefault = true;
            state.resumeAt = window.performance.now() + 900;
            controls.autoRotate = false;
            controls.autoRotateSpeed = 0;
        }

        container.addEventListener('pointerdown', function (event) {
            state.dragging = true;
            state.pointerMoved = false;
            state.dragVelocity = 0;
            state.lastX = event.clientX;
            state.lastTime = window.performance.now();
            state.inertiaActive = false;
            state.returnToDefault = false;
            state.resumeAt = 0;
            state.currentSpeed = 0;
            controls.autoRotate = false;
            controls.autoRotateSpeed = 0;
            container.classList.add('is-dragging');
        });

        container.addEventListener('pointermove', function (event) {
            if (!state.dragging) {
                return;
            }
            const now = window.performance.now();
            const dx = event.clientX - state.lastX;
            const dt = Math.max(1, now - state.lastTime);
            if (Math.abs(dx) > 0.7) {
                state.pointerMoved = true;
            }
            const nextVelocity = dx / dt;
            state.dragVelocity = (state.dragVelocity * 0.65) + (nextVelocity * 0.35);
            state.lastX = event.clientX;
            state.lastTime = now;
        });

        ['pointerup', 'pointerleave', 'pointercancel'].forEach(function (eventName) {
            container.addEventListener(eventName, finishDrag);
        });

        animate();
        container._analyticsGlobeState = state;
        return state;
    }

    function initGlobe(container) {
        if (!window.Globe || container._analyticsGlobe) {
            return;
        }

        const globe = new Globe(container, { animateIn: false, waitForGlobeReady: true })
            .backgroundColor('rgba(0,0,0,0)')
            .globeImageUrl('https://cdn.jsdelivr.net/npm/three-globe/example/img/earth-blue-marble.jpg')
            .bumpImageUrl('https://cdn.jsdelivr.net/npm/three-globe/example/img/earth-topology.png')
            .showAtmosphere(true)
            .atmosphereColor('#7ec3ff')
            .atmosphereAltitude(0.075)
            .htmlLat('lat')
            .htmlLng('lng')
            .htmlAltitude('altitude')
            .htmlElement(function (point) {
                const dot = document.createElement('span');
                dot.className = 'analytics-globe-dot';
                dot.title = markerTitleText(point);
                dot.setAttribute('aria-label', markerTitleText(point));
                return dot;
            });

        const width = container.clientWidth || 320;
        const height = container.clientHeight || 320;
        globe.width(width).height(height);
        globe.pointOfView({ lat: 18, lng: 12, altitude: 1.82 }, 0);

        attachGlobeInteraction(container, globe);

        container._analyticsGlobe = globe;
        container._analyticsResizeHandler = function () {
            if (!container._analyticsGlobe) {
                return;
            }
            container._analyticsGlobe
                .width(container.clientWidth || 320)
                .height(container.clientHeight || 320);
        };
        window.addEventListener('resize', container._analyticsResizeHandler);
    }

    function renderGlobe(container, points) {
        if (!window.Globe) {
            return;
        }
        initGlobe(container);

        const globe = container._analyticsGlobe;
        const globePoints = points.map(function (point) {
            return {
                lat: point.latitude,
                lng: point.longitude,
                altitude: 0,
                count: point.count || 1,
                label: point.label || 'Približna lokacija posjeta',
            };
        });

        globe.pointsData([]);
        globe.htmlElementsData(globePoints);

        if (globePoints.length) {
            globe.pointOfView({
                lat: globePoints[0].lat,
                lng: globePoints[0].lng,
                altitude: globePoints.length === 1 ? 1.38 : 1.82,
            }, 900);
        } else {
            globe.pointOfView({ lat: 18, lng: 12, altitude: 1.82 }, 900);
        }
    }

    function renderAnalyticsMap(container, points) {
        const style = container.dataset.mapStyle || 'map';
        if (style === 'globe') {
            renderGlobe(container, points);
        } else {
            renderLeafletMap(container, points);
        }
    }

    function initAllAnalyticsMaps() {
        document.querySelectorAll('[data-analytics-map]').forEach(function (container) {
            renderAnalyticsMap(container, readMapPoints(container));
        });
    }

    function updateAllAnalyticsMaps(points) {
        const normalizedPoints = normalizePoints(points);

        document.querySelectorAll('[data-analytics-map]').forEach(function (container) {
            renderAnalyticsMap(container, normalizedPoints);
        });

        document.querySelectorAll('.js-analytics-map-count').forEach(function (item) {
            item.textContent = normalizedPoints.length;
        });

        document.querySelectorAll('[data-analytics-map-wrapper]').forEach(function (wrapper) {
            const note = wrapper.querySelector('.js-analytics-map-note');
            if (!note) {
                return;
            }
            const style = wrapper.dataset.mapVariant || 'map';
            if (!normalizedPoints.length) {
                note.textContent = 'Karta će se popuniti kad barem jedan posjetitelj dopusti približnu lokaciju.';
                return;
            }
            note.textContent = style === 'globe'
                ? 'Povuci globus mišem ili zumiraj kotačićem: jači zamah ga vrti u tom smjeru pa se polako smiruje i vrati na laganu zadanu vrtnju.'
                : 'Označene su približne lokacije posjeta koje su dopustile lokaciju. Kartu možeš pomicati mišem i zumirati kotačićem.';
        });
    }

    window.blogAnalyticsMaps = {
        initAll: initAllAnalyticsMaps,
        updateAll: updateAllAnalyticsMaps,
    };

    document.addEventListener('DOMContentLoaded', initAllAnalyticsMaps);
})();
</script>

