                    - tailHeadingX * offset
                    + normalX * (lateralSway + tailFan)
                    - tailHeadingX * bobSway * 0.2;
                const targetY = lastY
                    - tailHeadingY * offset
                    + normalY * (lateralSway + tailFan)
                    + tailHeadingY * bobSway * 0.2;

