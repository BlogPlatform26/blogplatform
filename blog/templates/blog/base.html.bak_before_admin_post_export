        from{ transform:translate(-50%, -50%) rotate(var(--rotate, -18deg)) scale(1); opacity:0.96; }
        to{ transform:translate(calc(-50% + var(--dx, 0px)), calc(-50% + var(--dy, -12px))) rotate(var(--rotate, -18deg)) scale(0.4); opacity:0; }
    }
        @keyframes blogCursorLoveShot{
        0%{ transform:translate(-50%, -50%) scale(0.8) rotate(-6deg); opacity:0; }
        12%{ transform:translate(calc(-50% + 8px), calc(-50% - 10px)) scale(1) rotate(-2deg); opacity:1; }
        62%{ transform:translate(calc(-50% + var(--dx, 110px)), calc(-50% + var(--dy, -84px))) scale(1.02) rotate(3deg); opacity:1; }
        100%{ transform:translate(calc(-50% + var(--dx, 136px)), calc(-50% + var(--dy, -116px))) scale(0.92) rotate(5deg); opacity:0; }
