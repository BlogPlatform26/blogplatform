            setActiveNodePosition(lastX, lastY, false);
            tailLastTick = 0;
            tailMotionEnergy = 0;
            tailStretchEnergy = 0;
        });

        document.addEventListener('visibilitychange', function () {
            if (document.hidden) {
                setActiveNodePosition(lastX, lastY, false);
                tailLastTick = 0;
                tailMotionEnergy = 0;
                tailStretchEnergy = 0;
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initBlogCursorEffects, { once: true });
    } else {
        initBlogCursorEffects();
    }
})();
</script>



<script>
document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll('input[type="password"]').forEach(function (input) {
        if (input.dataset.passwordToggleReady === "1") return;
        input.dataset.passwordToggleReady = "1";

        const wrapper = document.createElement("div");
        wrapper.className = "input-group password-toggle-group";

        const parent = input.parentNode;
        parent.insertBefore(wrapper, input);
        wrapper.appendChild(input);

        const button = document.createElement("button");
        button.type = "button";
        button.className = "btn btn-outline-secondary password-toggle-btn";
        button.setAttribute("aria-label", "Prikaži lozinku");
        button.setAttribute("title", "Prikaži lozinku");
        button.innerHTML = '<i class="bi bi-eye" aria-hidden="true"></i>';

        button.addEventListener("click", function () {
            const isHidden = input.type === "password";
            const icon = button.querySelector("i");

            input.type = isHidden ? "text" : "password";

            if (icon) {
                icon.className = isHidden ? "bi bi-eye-slash" : "bi bi-eye";
            }

            button.setAttribute("aria-label", isHidden ? "Sakrij lozinku" : "Prikaži lozinku");
            button.setAttribute("title", isHidden ? "Sakrij lozinku" : "Prikaži lozinku");
        });

        wrapper.appendChild(button);
    });
});
</script>

