<script>
(function () {
    const tracking = {
        ownerUsername: "{{ analytics_tracking.owner_username|escapejs }}",
        pageLabel: "{{ analytics_tracking.page_label|escapejs }}",
        geoEnabled: {{ analytics_tracking.geo_enabled|yesno:"true,false" }},
        pingUrl: "{% url 'analytics_ping' %}",
    };

    function getCookie(name) {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) {
            return parts.pop().split(';').shift();
        }
        return '';
    }

    function getCsrfToken() {
        const cookieToken = getCookie('csrftoken');
        if (cookieToken) {
            return cookieToken;
        }
        const meta = document.querySelector('meta[name="csrf-token"]');
        if (meta && meta.content && meta.content !== 'NOTPROVIDED') {
            return meta.content;
        }
        const input = document.querySelector('input[name="csrfmiddlewaretoken"]');
        return input ? input.value : '';
    }

    function getVisitorToken() {
        const key = 'blogAnalyticsVisitorToken';
        try {
            let token = window.localStorage.getItem(key);
            if (!token) {
                token = `v-${Math.random().toString(36).slice(2)}${Date.now().toString(36)}`;
                window.localStorage.setItem(key, token);
            }
            return token;
        } catch (error) {
            return `v-${Date.now().toString(36)}`;
        }
    }

    function getStoredCoords() {
        try {
            const raw = window.localStorage.getItem(`blogAnalyticsCoords:${tracking.ownerUsername}`);
            return raw ? JSON.parse(raw) : null;
        } catch (error) {
            return null;
        }
    }

    function storeCoords(coords) {
        try {
            window.localStorage.setItem(`blogAnalyticsCoords:${tracking.ownerUsername}`, JSON.stringify(coords));
        } catch (error) {}
    }

    function markGeoDenied() {
        try {
            window.localStorage.setItem(`blogAnalyticsGeoDenied:${tracking.ownerUsername}`, '1');
        } catch (error) {}
    }

    function isGeoDenied() {
        try {
            return window.localStorage.getItem(`blogAnalyticsGeoDenied:${tracking.ownerUsername}`) === '1';
        } catch (error) {
            return false;
        }
    }

    function renderPages(container, pageBreakdown) {
        if (!container) return;
        if (!Array.isArray(pageBreakdown) || !pageBreakdown.length) {
            container.innerHTML = '<div class="small text-muted">Trenutno nema aktivnih stranica.</div>';
            return;
        }

        container.innerHTML = pageBreakdown.map(function (item) {
            return '<div class="live-analytics-page-row"><span>' + item.label + '</span><strong>' + item.count + '</strong></div>';
        }).join('');
    }

    function updateWidgets(summary) {
        if (!summary) return;
        document.querySelectorAll('[data-summary-url]').forEach(function (widget) {
            const activeNow = widget.querySelector('.js-analytics-active-now');
            const activeRecent = widget.querySelector('.js-analytics-active-recent');
            const todayUnique = widget.querySelector('.js-analytics-today-unique');
            const pagesWrap = widget.querySelector('.js-analytics-pages');
            const mapCount = widget.querySelector('.js-analytics-map-count');

            if (activeNow) activeNow.textContent = summary.active_now ?? 0;
            if (activeRecent) activeRecent.textContent = summary.active_recent ?? 0;
            if (todayUnique) todayUnique.textContent = summary.today_unique ?? 0;
            if (pagesWrap) renderPages(pagesWrap, summary.page_breakdown || []);
            if (mapCount) mapCount.textContent = (summary.map_points || []).length;
        });

        if (window.blogAnalyticsMaps) {
            window.blogAnalyticsMaps.updateAll(summary.map_points || []);
        }
    }

    function sendPing(extra) {
        const payload = Object.assign({
            owner_username: tracking.ownerUsername,
            visitor_token: getVisitorToken(),
            page_label: tracking.pageLabel,
            path: window.location.pathname,
            language: navigator.language || '',
            timezone_name: (window.Intl && Intl.DateTimeFormat().resolvedOptions().timeZone) || '',
        }, extra || {});

        fetch(tracking.pingUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCsrfToken(),
            },
            body: JSON.stringify(payload),
        })
        .then(function (response) {
            if (!response.ok) {
                throw new Error('Ping nije uspio.');
            }
            return response.json();
        })
        .then(function (data) {
            if (data && data.summary) {
                updateWidgets(data.summary);
            }
        })
        .catch(function () {});
    }

    const savedCoords = getStoredCoords();
    if (savedCoords && typeof savedCoords.latitude === 'number' && typeof savedCoords.longitude === 'number') {
        sendPing(savedCoords);
    } else {
        sendPing();
    }

    if (tracking.geoEnabled && !savedCoords && !isGeoDenied() && navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function (position) {
                const coords = {
                    latitude: Number(position.coords.latitude.toFixed(1)),
                    longitude: Number(position.coords.longitude.toFixed(1)),
                };
                storeCoords(coords);
                sendPing(coords);
            },
            function (error) {
                if (error && error.code === 1) {
                    markGeoDenied();
                }
            },
            {
                enableHighAccuracy: false,
                timeout: 3500,
                maximumAge: 86400000,
            }
        );
    }

    window.setInterval(function () {
        const coords = getStoredCoords();
        sendPing(coords || {});
    }, 45000);
})();
</script>
