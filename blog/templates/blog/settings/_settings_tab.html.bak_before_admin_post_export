{% load static %}
<!-- POSTAVKE BLOGA -->
{% if request.GET.tab == "postavke" %}

    <h4 class="mb-4">Postavke bloga</h4>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a href="?tab=postavke&settings_tab=opcenito"
               class="nav-link {% if settings_tab == 'opcenito' %}active{% endif %}">
                Općenito
            </a>
        </li>
        <li class="nav-item">
            <a href="?tab=postavke&settings_tab=postovi"
               class="nav-link {% if settings_tab == 'postovi' %}active{% endif %}">
                Postovi
            </a>
        </li>
        <li class="nav-item">
            <a href="?tab=postavke&settings_tab=komentari"
               class="nav-link {% if settings_tab == 'komentari' %}active{% endif %}">
                Komentari
            </a>
        </li>
        <li class="nav-item">
            <a href="?tab=postavke&settings_tab=posjetitelji"
               class="nav-link {% if settings_tab == 'posjetitelji' %}active{% endif %}">
                Posjetitelji
            </a>
        </li>
        <li class="nav-item">
            <a href="?tab=postavke&settings_tab=sigurnost"
               class="nav-link {% if settings_tab == 'sigurnost' %}active{% endif %}">
                Sigurnost i privatnost
            </a>
        </li>
    </ul>

    <form method="POST" enctype="multipart/form-data" id="avatarForm">
        {% csrf_token %}

        {% if settings_tab == 'opcenito' %}
            <div class="card p-4 mb-4 shadow-sm">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h5 class="mb-1">Avatar</h5>
                        <div class="small text-muted">Okrugli izrez kao na Gmailu, s pomicanjem, zumom i rotacijom.</div>
                    </div>
                </div>

                <div class="d-flex flex-wrap align-items-start gap-4">
                    <div class="text-center avatar-current-wrap">
                        {% if user.profile.avatar %}
                            <img src="{{ user.profile.avatar.url }}" id="currentAvatarImage" width="108" height="108" class="avatar-current-image">
                        {% else %}
                            <img src="{% static 'images/default-avatar.jpg' %}" id="currentAvatarImage" width="108" height="108" class="avatar-current-image">
                        {% endif %}

                        <div class="small text-muted mt-2">Trenutni avatar</div>
                    </div>

                    <div class="flex-grow-1" style="min-width:280px;">
                        <label class="form-label d-block" for="avatarInput">Promijeni avatar</label>
                        <input type="file" id="avatarInput" accept="image/*" class="form-control">
                        <div class="small text-muted mt-2">Odaberi sliku, pomakni kadar, zumiraj i spremi okrugli izrez.</div>

                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button type="button" class="btn btn-outline-primary btn-sm" id="avatarChangeBtn">
                                Odaberi i uredi avatar
                            </button>

                            {% if user.profile.avatar %}
                                <button type="submit" name="delete_avatar" value="1" class="btn btn-outline-danger btn-sm">
                                    Izbriši avatar
                                </button>
                            {% endif %}
                        </div>

                        <input type="hidden" name="cropped_image" id="croppedImage">
                    </div>

                    <div class="avatar-live-preview text-center">
                        <div class="avatar-preview-circle" id="avatarPreviewCircle">
                            <canvas id="avatarPreviewCanvas" width="160" height="160"></canvas>
                        </div>
                        <div class="small text-muted mt-2">Preview (okruglo)</div>

                        <div class="d-flex justify-content-center align-items-center gap-2 mt-3">
                            <div class="avatar-preview-mini">
                                <canvas id="avatarPreviewMiniCanvas" width="26" height="26"></canvas>
                            </div>
                            <div class="small text-muted">Kako izgleda pored imena</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card p-4 mb-4 shadow-sm">
                <h5 class="mb-3">Kratka poruka bloga</h5>

                <div class="mb-2">
                    <label class="form-label" for="blogTaglineInput">Poruka ispod naslova bloga</label>
                    <input
                        type="text"
                        id="blogTaglineInput"
                        name="blog_tagline"
                        class="form-control"
                        maxlength="220"
                        value="{{ user.profile.blog_tagline }}"
                        placeholder="npr. Mjesto gdje ljubav postaje riječ, a riječ postaje stih.">
                    <div class="form-text">Kratka rečenica koja se prikazuje odmah ispod naslova bloga.</div>
                </div>
            </div>

            <div class="card p-4 mt-4 shadow-sm">
                <h5 class="mb-3">Slika na vrhu bloga</h5>

                <div class="mb-3">
                    <label class="form-label d-block">Odaberi sliku</label>
                    <input type="file" name="blog_banner" class="form-control" accept="image/*">
                    <div class="small text-muted mt-2">
                        Slika će se prikazivati na vrhu tvog bloga. Maksimalna veličina je 2 MB,
                        a maksimalne dimenzije 2200 x 900 px.
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Pozicija slike</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="blog_banner_position" value="left" id="bannerLeft" {% if user.profile.blog_banner_position == "left" %}checked{% endif %}>
                        <label class="form-check-label" for="bannerLeft">Lijevo</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="blog_banner_position" value="center" id="bannerCenter" {% if user.profile.blog_banner_position == "center" %}checked{% endif %}>
                        <label class="form-check-label" for="bannerCenter">Sredina</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="blog_banner_position" value="right" id="bannerRight" {% if user.profile.blog_banner_position == "right" %}checked{% endif %}>
                        <label class="form-check-label" for="bannerRight">Desno</label>
                    </div>
                </div>

                {% if user.profile.blog_banner %}
                    <div class="mb-3">
                        <label class="form-label d-block">Trenutna slika</label>
                        <img src="{{ user.profile.blog_banner.url }}" class="img-fluid rounded" style="max-height:180px; object-fit:contain;">
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" name="delete_blog_banner" value="1" id="deleteBlogBanner">
                            <label class="form-check-label" for="deleteBlogBanner">Izbriši sliku</label>
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="modal fade avatar-crop-modal" id="avatarCropModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header border-0">
                            <div>
                                <h5 class="modal-title mb-1">Obrezivanje avatara</h5>
                                <div class="small text-muted">Povuci sliku, zumiraj i spremi okrugli izrez.</div>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
                        </div>

                        <div class="modal-body pt-0">
                            <div class="avatar-crop-stage">
                                <div class="avatar-crop-frame">
                                    <img id="avatarCropImage" alt="Avatar preview">
                                </div>
                            </div>

                            <div class="avatar-crop-controls mt-4">
                                <div class="avatar-crop-control-row">
                                    <label for="avatarZoomRange" class="form-label mb-0">Zum</label>
                                    <input type="range" id="avatarZoomRange" min="0" max="100" value="50" class="form-range">
                                </div>

                                <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mt-3">
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-outline-secondary btn-sm" id="avatarRotateBtn">Zakreni</button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" id="avatarResetBtn">Reset</button>
                                    </div>

                                    <button type="button" class="btn btn-primary" id="avatarApplyBtn">Primijeni avatar</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        {% elif settings_tab == 'postovi' %}
            <div class="card p-4 mb-4 shadow-sm">
                <h5 class="mb-3">Prikaz postova</h5>

                <div class="mb-4">
                    <label class="form-label d-block">Broj postova po stranici</label>
                    <select name="posts_per_page" class="form-select" style="max-width:220px;">
                        <option value="5" {% if blog_preferences.posts_per_page == 5 %}selected{% endif %}>5 postova</option>
                        <option value="10" {% if blog_preferences.posts_per_page == 10 %}selected{% endif %}>10 postova</option>
                        <option value="15" {% if blog_preferences.posts_per_page == 15 %}selected{% endif %}>15 postova</option>
                        <option value="20" {% if blog_preferences.posts_per_page == 20 %}selected{% endif %}>20 postova</option>
                    </select>
                </div>

                <div>
                    <label class="form-label d-block">Prikaz arhive postova</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="blog_archive_mode" value="both" id="archiveBoth" {% if blog_preferences.blog_archive_mode == 'both' %}checked{% endif %}>
                        <label class="form-check-label" for="archiveBoth">Kalendar i arhiva</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="blog_archive_mode" value="calendar" id="archiveCalendar" {% if blog_preferences.blog_archive_mode == 'calendar' %}checked{% endif %}>
                        <label class="form-check-label" for="archiveCalendar">Samo kalendar</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="blog_archive_mode" value="list" id="archiveList" {% if blog_preferences.blog_archive_mode == 'list' %}checked{% endif %}>
                        <label class="form-check-label" for="archiveList">Samo arhiva</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="blog_archive_mode" value="none" id="archiveNone" {% if blog_preferences.blog_archive_mode == 'none' %}checked{% endif %}>
                        <label class="form-check-label" for="archiveNone">Bez arhive</label>
                    </div>
                </div>
            </div>

        {% elif settings_tab == 'komentari' %}
            <div class="card p-4 mb-4 shadow-sm">
                <h5 class="mb-3">Komentari</h5>

                <div class="mb-4">
                    <label class="form-label d-block">Prikaz komentara ispod postova</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="show_post_comments" value="1" id="showCommentsYes" {% if blog_preferences.show_post_comments %}checked{% endif %}>
                        <label class="form-check-label" for="showCommentsYes">Prikaži komentare ispod postova</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="show_post_comments" value="0" id="showCommentsNo" {% if not blog_preferences.show_post_comments %}checked{% endif %}>
                        <label class="form-check-label" for="showCommentsNo">Nemoj prikazivati komentare ispod postova</label>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label d-block">Komentiranje</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="allow_comments" value="1" id="allowCommentsYes" {% if blog_preferences.allow_comments %}checked{% endif %}>
                        <label class="form-check-label" for="allowCommentsYes">Dopusti komentiranje</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="allow_comments" value="0" id="allowCommentsNo" {% if not blog_preferences.allow_comments %}checked{% endif %}>
                        <label class="form-check-label" for="allowCommentsNo">Isključi komentiranje na blogu</label>
                    </div>
                </div>

                <div>
                    <label class="form-label d-block">Anonimni komentari</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="allow_anonymous_comments" value="1" id="allowAnonymousYes" {% if allow_anonymous_comments %}checked{% endif %}>
                        <label class="form-check-label" for="allowAnonymousYes">Dopusti anonimne komentare</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="allow_anonymous_comments" value="0" id="allowAnonymousNo" {% if not allow_anonymous_comments %}checked{% endif %}>
                        <label class="form-check-label" for="allowAnonymousNo">Zabrani anonimne komentare</label>
                    </div>
                </div>
            </div>
        {% elif settings_tab == 'posjetitelji' %}
            <div class="card p-4 mb-4 shadow-sm">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <div>
                        <h5 class="mb-1">Posjetitelji i analitika uživo</h5>
                        <div class="small text-muted">Ovdje uključuješ dodatne widgete koji nisu uključeni po defaultu.</div>
                    </div>
                    <span class="badge text-bg-light border">Eksperimentalno</span>
                </div>

                <div class="form-check form-switch mb-3">
                    <input type="hidden" name="analytics_live_counter_enabled" value="0">
                    <input class="form-check-input" type="checkbox" name="analytics_live_counter_enabled" value="1" id="analyticsLiveCounter" {% if blog_preferences.analytics_live_counter_enabled %}checked{% endif %}>
                    <label class="form-check-label" for="analyticsLiveCounter">Broj aktivnih posjetitelja</label>
                    <div class="small text-muted mt-1">Prikazuje trenutno aktivne, zadnjih 15 minuta i današnje posjetitelje.</div>
                </div>

                <div class="form-check form-switch mb-3">
                    <input type="hidden" name="analytics_active_pages_enabled" value="0">
                    <input class="form-check-input" type="checkbox" name="analytics_active_pages_enabled" value="1" id="analyticsActivePages" {% if blog_preferences.analytics_active_pages_enabled %}checked{% endif %}>
                    <label class="form-check-label" for="analyticsActivePages">Aktivne stranice</label>
                    <div class="small text-muted mt-1">Prikazuje jesu li ljudi sada na naslovnici bloga ili na detalju posta.</div>
                </div>

                <div class="form-check form-switch mb-3">
                    <input type="hidden" name="analytics_map_enabled" value="0">
                    <input class="form-check-input" type="checkbox" name="analytics_map_enabled" value="1" id="analyticsMap" {% if blog_preferences.analytics_map_enabled %}checked{% endif %}>
                    <label class="form-check-label" for="analyticsMap">Karta / globus lokacija posjeta</label>
                    <div class="small text-muted mt-1">Prikazuje približne točke posjeta na karti ili u globe prikazu.</div>
                </div>

                <div class="form-check form-switch mb-4">
                    <input type="hidden" name="analytics_geo_enabled" value="0">
                    <input class="form-check-input" type="checkbox" name="analytics_geo_enabled" value="1" id="analyticsGeo" {% if blog_preferences.analytics_geo_enabled %}checked{% endif %}>
                    <label class="form-check-label" for="analyticsGeo">Traži približnu lokaciju posjetitelja</label>
                    <div class="small text-muted mt-1">Preglednik će posjetitelju ponuditi dozvolu za približnu lokaciju. Bez toga karta ostaje prazna.</div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Položaj widgeta na blogu</label>
                        <select class="form-select" name="analytics_widget_side">
                            <option value="right_top" {% if blog_preferences.analytics_widget_side == 'right_top' %}selected{% endif %}>Desno gore</option>
                            <option value="right_bottom" {% if blog_preferences.analytics_widget_side == 'right_bottom' %}selected{% endif %}>Desno dolje</option>
                            <option value="left_top" {% if blog_preferences.analytics_widget_side == 'left_top' %}selected{% endif %}>Lijevo gore (ispod kalendara i arhive)</option>
                            <option value="left_bottom" {% if blog_preferences.analytics_widget_side == 'left_bottom' %}selected{% endif %}>Lijevo dolje (ispod boxeva)</option>
                            <option value="footer_full" {% if blog_preferences.analytics_widget_side == 'footer_full' %}selected{% endif %}>Na dnu iznad footera (cijelom širinom)</option>
                        </select>
                        <div class="small text-muted mt-2">Lijevo gore je ispod kalendara i arhive, lijevo dolje je ispod boxeva, a donja varijanta ide u jedan široki red iznad footera.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Veličina kartica s brojevima</label>
                        <select class="form-select" name="analytics_stat_card_size">
                            <option value="small" {% if blog_preferences.analytics_stat_card_size == 'small' %}selected{% endif %}>Malo</option>
                            <option value="medium" {% if blog_preferences.analytics_stat_card_size == 'medium' %}selected{% endif %}>Srednje</option>
                            <option value="large" {% if blog_preferences.analytics_stat_card_size == 'large' %}selected{% endif %}>Veliko</option>
                        </select>
                        <div class="small text-muted mt-2">Mijenja veličinu kartica Trenutno, 15 min i Danas u widgetu posjetitelja.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Stil prikaza lokacija</label>
                        <select class="form-select" name="analytics_map_variant">
                            <option value="map" {% if blog_preferences.analytics_map_variant == 'map' %}selected{% endif %}>Karta svijeta</option>
                            <option value="globe" {% if blog_preferences.analytics_map_variant == 'globe' %}selected{% endif %}>Globus</option>
                        </select>
                    </div>
                </div>
            </div>

        {% elif settings_tab == 'sigurnost' %}
            <div class="card p-4 mb-4 shadow-sm">
                <h5 class="mb-1">Sigurnost i privatnost</h5>
                <div class="text-muted small">Ovdje upravljaš blokiranim i ograničenim korisnicima.

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-2">Izvoz mojih postova</h5>
        <p class="text-muted mb-3">
            Preuzmi ZIP datoteku sa svojim postovima. U izvoz ulaze tvoji postovi,
            HTML prikaz postova, JSON/CSV pregled i slike koje pripadaju postovima.
            Komentari drugih korisnika, lajkovi, notifikacije i sigurnosni zapisi nisu uključeni.
        </p>
        <a href="{% url 'export_my_posts' %}" class="btn btn-outline-primary">
            Preuzmi moje postove
        </a>
    </div>
</div>
</div>
            </div>
        {% endif %}

        {% if settings_tab != 'sigurnost' %}
        <button type="submit" class="btn btn-primary">Spremi promjene</button>
        {% endif %}
    </form>

    {% if settings_tab == 'sigurnost' %}
    <div class="card p-4 mt-4 shadow-sm">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div>
                <h5 class="mb-1">Blokirani korisnici</h5>
                <div class="text-muted small">Blokirani korisnici ne mogu pratiti, lajkati ni komentirati.</div>
            </div>
            <span class="badge text-bg-secondary">{{ blocked_users|length }}</span>
        </div>

        {% if blocked_users %}
            <div class="list-group">
                {% for block in blocked_users %}
                    <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-3">
                            {% if block.blocked.profile.avatar %}
                                <img src="{{ block.blocked.profile.avatar.url }}" width="42" height="42" style="border-radius:50%; object-fit:cover;">
                            {% else %}
                                <img src="{% static 'images/default-avatar.jpg' %}" width="42" height="42" style="border-radius:50%; object-fit:cover;">
                            {% endif %}
                            <div>
                                <div class="fw-semibold">{{ block.blocked.profile.blog_name|default:block.blocked.username }}</div>
                                <div class="small text-muted">@{{ block.blocked.username }}</div>
                            </div>
                        </div>

                        <form method="POST" class="m-0">
                            {% csrf_token %}
                            <input type="hidden" name="unblock_user_id" value="{{ block.blocked.id }}">
                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Jesi li siguran da želiš odblokirati ovog korisnika?')">Odblokiraj</button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-muted small">Trenutno nemaš blokiranih korisnika.</div>
        {% endif %}
    </div>

    <div class="card p-4 mt-4 shadow-sm">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div>
                <h5 class="mb-1">Ograničeni korisnici</h5>
                <div class="text-muted small">Ograničeni korisnici mogu čitati blog, ali ne mogu pratiti, lajkati ni komentirati.</div>
            </div>
            <span class="badge text-bg-secondary">{{ restricted_users|length }}</span>
        </div>

        {% if restricted_users %}
            <div class="list-group">
                {% for restriction in restricted_users %}
                    <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-3">
                            {% if restriction.restricted.profile.avatar %}
                                <img src="{{ restriction.restricted.profile.avatar.url }}" width="42" height="42" style="border-radius:50%; object-fit:cover;">
                            {% else %}
                                <img src="{% static 'images/default-avatar.jpg' %}" width="42" height="42" style="border-radius:50%; object-fit:cover;">
                            {% endif %}
                            <div>
                                <div class="fw-semibold">{{ restriction.restricted.profile.blog_name|default:restriction.restricted.username }}</div>
                                <div class="small text-muted">@{{ restriction.restricted.username }}</div>
                            </div>
                        </div>

                        <form method="POST" class="m-0">
                            {% csrf_token %}
                            <input type="hidden" name="remove_restriction_user_id" value="{{ restriction.restricted.id }}">
                            <button type="submit" class="btn btn-outline-warning btn-sm" onclick="return confirm('Jesi li siguran da želiš maknuti ograničenje ovom korisniku?')">Makni ograničenje</button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-muted small">Trenutno nemaš ograničenih korisnika.</div>
        {% endif %}
    </div>
    {% endif %}

{% endif %}
